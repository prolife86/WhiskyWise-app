<?xml version="1.0" encoding="utf-8"?>
<!--
    Share card layout — rendered off-screen to a Bitmap by WhiskyShareCard.kt.
    Fixed width of 1080px at 3× density → 360dp. Never inflated into the live UI.
    Keep all dimensions in dp so the Canvas render scales correctly.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="360dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Photo (shown only when a front photo exists) ── -->
    <FrameLayout
        android:id="@+id/photoContainer"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/ivPhoto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="@null" />

        <!-- Gradient fade into card body -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_photo_fade" />

        <!-- Status badge -->
        <TextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="@drawable/bg_status_badge"
            android:textColor="@color/on_surface_dim"
            android:textSize="10sp"
            android:letterSpacing="0.12" />

    </FrameLayout>

    <!-- ── Body ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="4dp">

        <!-- Name -->
        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="22sp"
            android:lineSpacingMultiplier="1.1" />

        <!-- Distillery · Region -->
        <TextView
            android:id="@+id/tvDistillery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/amber"
            android:textSize="13sp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="14dp" />

        <!-- Stats row: Age | ABV | Price | Score -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/surface"
            android:layout_marginBottom="14dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="10dp">
                <TextView android:id="@+id/tvAge"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/on_surface" android:textSize="18sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="AGE" android:textColor="@color/on_surface_dim"
                    android:textSize="9sp" android:letterSpacing="0.1" android:gravity="center"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/divider"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="10dp">
                <TextView android:id="@+id/tvAbv"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/on_surface" android:textSize="18sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ABV" android:textColor="@color/on_surface_dim"
                    android:textSize="9sp" android:letterSpacing="0.1" android:gravity="center"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/divider"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="10dp">
                <TextView android:id="@+id/tvPrice"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/on_surface" android:textSize="18sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PRICE" android:textColor="@color/on_surface_dim"
                    android:textSize="9sp" android:letterSpacing="0.1" android:gravity="center"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/divider"/>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:gravity="center" android:padding="10dp">
                <TextView android:id="@+id/tvScore"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="@color/amber" android:textSize="18sp" android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="SCORE" android:textColor="@color/on_surface_dim"
                    android:textSize="9sp" android:letterSpacing="0.1" android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Tasting notes (hidden when all blank) -->
        <LinearLayout
            android:id="@+id/notesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Nose -->
            <LinearLayout android:id="@+id/rowNose"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="NOSE" android:textColor="@color/amber"
                    android:textSize="9sp" android:letterSpacing="0.12" android:paddingTop="2dp"/>
                <TextView android:id="@+id/tvNose"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textColor="@color/on_surface_dim"
                    android:textSize="12sp" android:textStyle="italic" android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Palate -->
            <LinearLayout android:id="@+id/rowPalate"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="PALATE" android:textColor="@color/amber"
                    android:textSize="9sp" android:letterSpacing="0.12" android:paddingTop="2dp"/>
                <TextView android:id="@+id/tvPalate"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textColor="@color/on_surface_dim"
                    android:textSize="12sp" android:textStyle="italic" android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

            <!-- Finish -->
            <LinearLayout android:id="@+id/rowFinish"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <TextView android:layout_width="48dp" android:layout_height="wrap_content"
                    android:text="FINISH" android:textColor="@color/amber"
                    android:textSize="9sp" android:letterSpacing="0.12" android:paddingTop="2dp"/>
                <TextView android:id="@+id/tvFinish"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textColor="@color/on_surface_dim"
                    android:textSize="12sp" android:textStyle="italic" android:lineSpacingMultiplier="1.3"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Footer ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:id="@+id/tvFooterLabel"
            android:textColor="@color/amber_dark"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvRegion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface_dim"
            android:textSize="10sp"
            android:letterSpacing="0.08" />

    </LinearLayout>

</LinearLayout>
